---
import { site, nav } from '@/config/site';

const { pathname } = Astro.url;
---

<header id="site-header" class="relative sticky top-0 z-40 bg-[#FAFAF7]/95 backdrop-blur">
  <a
    href="#main"
    class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-btn focus:z-50"
  >
    Zum Hauptinhalt springen
  </a>

  <!-- Trust-Bar (Desktop) -->
  <div class="hidden lg:block bg-[#F5F5F0] border-b border-line/40">
    <div class="container-content py-2">
      <div class="flex items-center justify-center gap-5 text-[13px] text-ink/75">
        <span class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5" style="color:#D4A800" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          Seit {site.foundedYear}
        </span>
        <span class="text-ink-muted/40" aria-hidden="true">·</span>
        <span class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5" style="color:#D4A800" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/>
          </svg>
          Häusliche Krankenpflege in Wuppertal-{site.address.district}
        </span>
        <span class="text-ink-muted/40" aria-hidden="true">·</span>
        <span class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5" style="color:#D4A800" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Alle Pflegekassen
        </span>
      </div>
    </div>
  </div>

  <div class="container-content relative flex items-stretch justify-between h-[128px] md:h-[148px] gap-6">
    <!-- Logo + Seit-Badge -->
    <a href="/" class="absolute inset-y-0 left-1/2 -translate-x-1/2 lg:static lg:inset-auto lg:translate-x-0 shrink-0 flex flex-col items-center justify-start pt-1" aria-label="Startseite">
      <img
        src="/images/logo.svg"
        alt="Pieper Häusliche Krankenpflege"
        class="h-[110px] md:h-[130px] w-auto transition-opacity hover:opacity-85"
      />
      <span class="text-[10px] font-bold tracking-[0.22em] uppercase leading-none -mt-6 md:-mt-10" style="color:#D4A800;">seit 1996</span>
    </a>

    <!-- Desktop Nav (volle Header-Höhe, Unterstreichung sitzt unten am Rand) -->
    <nav aria-label="Hauptnavigation" class="hidden lg:flex items-stretch">
      {nav.map((item) => {
        const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));

        if (item.children) {
          return (
            <div class="relative group/drop flex items-stretch after:content-[''] after:absolute after:top-full after:left-0 after:right-0 after:h-3">
              <a
                href={item.href}
                class:list={[
                  'relative h-full flex items-center gap-1 px-4 text-body font-medium whitespace-nowrap transition-colors',
                  isActive ? 'text-primary' : 'text-ink hover:text-primary',
                ]}
                style={isActive ? '' : 'color:#374151'}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
                <svg
                  class="w-3 h-3 transition-transform duration-200 group-hover/drop:rotate-180 group-focus-within/drop:rotate-180 opacity-60"
                  xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                >
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
                {isActive && (
                  <span class="absolute left-4 right-7 bottom-[42px] md:bottom-[50px] h-[2px] bg-primary" aria-hidden="true"></span>
                )}
              </a>
              <div class="absolute top-full left-0 hidden group-hover/drop:block group-focus-within/drop:block z-50">
                <ul
                  class="bg-white rounded-card shadow-lg border border-line py-1.5 min-w-[210px] mt-0"
                  role="list"
                >
                  {item.children.map((child) => {
                    const childActive = pathname === child.href;
                    return (
                      <li>
                        <a
                          href={child.href}
                          class:list={[
                            'block px-4 py-2.5 text-small font-medium whitespace-nowrap transition-colors',
                            childActive
                              ? 'text-primary'
                              : 'text-ink hover:text-primary',
                          ]}
                          style={childActive ? 'background:#EEF3FF' : ''}
                        >
                          {child.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </div>
          );
        }

        return (
          <a
            href={item.href}
            class:list={[
              'relative h-full flex items-center px-4 text-body font-medium whitespace-nowrap transition-colors',
              isActive ? 'text-primary' : 'text-ink hover:text-primary',
            ]}
            style={isActive ? '' : 'color:#374151'}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
            {isActive && (
              <span class="absolute left-4 right-4 bottom-[42px] md:bottom-[50px] h-[2px] bg-primary" aria-hidden="true"></span>
            )}
          </a>
        );
      })}
    </nav>

    <!-- Rechts: 24h-Bereitschaft + CTA + Burger -->
    <div class="ml-auto lg:ml-0 flex items-center gap-3 md:gap-4 shrink-0">
      <!-- 24h-Bereitschaft — Volle Variante (lg+): Eyebrow + Nummer; auf Mobile als Floating-Button neben WhatsApp -->
      <a
        href={site.contact.phoneHref}
        class="hidden lg:inline-flex items-center gap-3 pl-2 pr-3.5 py-1.5 rounded-btn border border-accent/40 bg-accent/10 hover:bg-accent/20 hover:border-accent/60 transition-colors group"
        aria-label={`24-Std.-Bereitschaft: ${site.contact.phone} anrufen`}
      >
        <span class="flex items-center justify-center w-9 h-9 rounded-full bg-accent text-primary-dark flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
          </svg>
        </span>
        <span class="flex flex-col leading-tight">
          <span class="text-[10px] font-bold tracking-[0.12em] uppercase text-accent-hover">24-Std.-Bereitschaft</span>
          <span class="text-body font-bold text-ink group-hover:text-accent-hover transition-colors whitespace-nowrap">{site.contact.phone}</span>
        </span>
      </a>

<button
        type="button"
        class="lg:hidden p-2 -mr-2 text-ink hover:text-primary"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-mobile-toggle
      >
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Corporate-Streifen (Blau → Rot → Gelb) -->
  <div
    class="absolute bottom-0 left-0 right-0 h-[4px]"
    style="background: linear-gradient(to right, #254BAC, #FC4937 50%, #FFE736);"
    aria-hidden="true"
  ></div>

  <!-- Mobile Nav -->
  <div id="mobile-nav" class="lg:hidden hidden border-t border-line bg-[#FAFAF7]" data-mobile-nav>
    <nav aria-label="Mobile Navigation" class="container-content py-4 flex flex-col gap-1">
      {nav.map((item) => {
        const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));

        if (item.children) {
          return (
            <div data-accordion>
              <div class="flex items-center">
                <a
                  href={item.href}
                  class:list={[
                    'flex-1 py-3 px-2 text-body font-medium rounded-btn',
                    isActive ? 'text-primary' : 'text-ink',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {item.label}
                </a>
                <button
                  type="button"
                  class="p-3 text-ink-muted hover:text-primary"
                  aria-expanded="false"
                  aria-label={`${item.label} Untermenü ein-/ausklappen`}
                  data-accordion-toggle
                >
                  <svg
                    class="w-4 h-4 transition-transform duration-200"
                    xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                    fill="none" stroke="currentColor" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                  >
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </button>
              </div>
              <div class="hidden" data-accordion-panel>
                <div class="pl-4 border-l-2 border-primary-soft ml-2 mb-2 flex flex-col gap-0.5">
                  {item.children.map((child) => {
                    const childActive = pathname === child.href;
                    return (
                      <a
                        href={child.href}
                        class:list={[
                          'block py-2.5 px-3 text-small font-medium rounded-btn transition-colors',
                          childActive
                            ? 'text-primary'
                            : 'text-ink-muted hover:text-primary',
                        ]}
                        style={childActive ? 'background:#EEF3FF' : ''}
                      >
                        {child.label}
                      </a>
                    );
                  })}
                </div>
              </div>
            </div>
          );
        }

        return (
          <a
            href={item.href}
            class:list={[
              'block py-3 px-2 text-body font-medium rounded-btn',
              isActive ? 'text-primary' : 'text-ink hover:text-primary',
            ]}
            style={isActive ? 'background:#EEF3FF' : ''}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}

      <div class="flex gap-3 pt-3 mt-1 border-t border-line">
        <a href={site.contact.phoneHref} class="btn-secondary btn-md flex-1">
          Anrufen
        </a>
        <a href="/kontakt/" class="btn-primary btn-md flex-1">
          Beratung
        </a>
      </div>

      <!-- Beratungseinsatz § 37.3 — hervorgehoben im Burger-Menü -->
      <a
        href="/beratungseinsatz/"
        class="flex items-center gap-3 mt-3 px-4 py-3.5 rounded-card bg-care text-white font-semibold shadow-sm active:scale-[0.98] transition-transform"
        aria-label="Beratungseinsatz nach § 37 Abs. 3 SGB XI anfragen"
      >
        <span class="flex items-center justify-center w-10 h-10 rounded-full bg-white/15 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/>
          </svg>
        </span>
        <span class="flex flex-col leading-tight">
          <span class="text-[10px] font-bold tracking-[0.14em] uppercase opacity-80">Pflichtberatung § 37.3</span>
          <span class="text-body font-bold">Beratungseinsatz anfragen</span>
        </span>
        <svg class="ml-auto w-4 h-4 opacity-60" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>

      <!-- 24h-Bereitschaft — hervorgehoben, ganz unten im Burger-Menü -->
      <a
        href={site.contact.phoneHref}
        class="flex items-center gap-3 mt-3 px-4 py-3.5 rounded-card bg-accent text-primary-dark font-semibold shadow-sm active:scale-[0.98] transition-transform"
        aria-label={`24-Std.-Bereitschaft: ${site.contact.phone} anrufen`}
      >
        <span class="flex items-center justify-center w-10 h-10 rounded-full bg-primary-dark/10 flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
          </svg>
        </span>
        <span class="flex flex-col leading-tight">
          <span class="text-[10px] font-bold tracking-[0.14em] uppercase opacity-70">24-Std.-Bereitschaft</span>
          <span class="text-body font-bold">{site.contact.phone}</span>
        </span>
        <svg class="ml-auto w-4 h-4 opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');
  const mobileNav = document.querySelector<HTMLElement>('[data-mobile-nav]');
  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = !mobileNav.classList.contains('hidden');
      mobileNav.classList.toggle('hidden', isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
      toggle.setAttribute('aria-label', !isOpen ? 'Menü schließen' : 'Menü öffnen');
    });
  }

  // Mobile accordion
  document.querySelectorAll<HTMLButtonElement>('[data-accordion-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.closest('[data-accordion]')?.querySelector<HTMLElement>('[data-accordion-panel]');
      if (!panel) return;
      const isOpen = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      btn.querySelector('svg')?.classList.toggle('rotate-180', !isOpen);
    });
  });

  // Close desktop dropdowns on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') (document.activeElement as HTMLElement)?.blur();
  });
</script>
