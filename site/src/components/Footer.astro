---
import { site } from '@/config/site';

const year = new Date().getFullYear();
---

<footer class="bg-primary text-white mt-section-mobile md:mt-section">
  <div class="container-content py-12 md:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    <div>
      <p class="font-heading text-h3 mb-3 font-bold">{site.shortName}</p>
      <p class="text-white/80 text-small leading-relaxed">
        {site.legalName}<br />
        {site.legalSuffix}
      </p>
      <address class="not-italic text-white/80 text-small leading-relaxed mt-4">
        {site.address.street}<br />
        {site.address.zip} {site.address.city}-{site.address.district}
      </address>
      <p class="mt-4 text-small">
        <a href={site.contact.phoneHref} class="text-white font-semibold hover:underline">
          📞 {site.contact.phone}
        </a>
      </p>
      <p class="mt-3 text-small text-white/70 leading-relaxed">
        <span class="text-white/90 font-semibold">Bürozeiten:</span><br />
        {site.officeHours.weekdays}<br />
        {site.officeHours.note}
      </p>
    </div>

    <nav aria-label="Service-Links">
      <p class="eyebrow text-white/60 mb-3">Pflege</p>
      <ul class="space-y-2 text-small">
        <li><a href="/leistungen/" class="text-white/90 hover:text-white hover:underline">Leistungen</a></li>
        <li><a href="/pflegegradrechner/" class="text-white/90 hover:text-white hover:underline">Pflegegradrechner</a></li>
        <li><a href="/ueber-uns/" class="text-white/90 hover:text-white hover:underline">Über uns</a></li>
        <li><a href="/ratgeber/" class="text-white/90 hover:text-white hover:underline">Ratgeber</a></li>
      </ul>
    </nav>

    <nav aria-label="Karriere & Kontakt-Links">
      <p class="eyebrow text-white/60 mb-3">Karriere & Kontakt</p>
      <ul class="space-y-2 text-small">
        <li><a href="/karriere/" class="text-white/90 hover:text-white hover:underline">Offene Stellen</a></li>
        <li><a href="/kontakt/" class="text-white/90 hover:text-white hover:underline">Kontakt</a></li>
        <li>
          <a href={`mailto:${site.contact.email}`} class="text-white/90 hover:text-white hover:underline">
            {site.contact.email}
          </a>
        </li>
      </ul>
    </nav>

    <nav aria-label="Rechtliches">
      <p class="eyebrow text-white/60 mb-3">Rechtliches</p>
      <ul class="space-y-2 text-small">
        <li><a href="/impressum/" class="text-white/90 hover:text-white hover:underline">Impressum</a></li>
        <li><a href="/datenschutz/" class="text-white/90 hover:text-white hover:underline">Datenschutzerklärung</a></li>
      </ul>
      <p class="eyebrow text-white/60 mt-6 mb-3">Vertrauen</p>
      <ul class="space-y-2 text-small text-white/80">
        <li>Alle gesetzlichen Pflegekassen</li>
        <li>24h Bereitschaft</li>
        <li>Examiniertes Team</li>
        <li>Mitglied {site.membership}</li>
      </ul>
    </nav>
  </div>

  <div class="border-t border-white/10">
    <div class="container-content py-5 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-small text-white/70">
      <p>© {year} {site.legalName} — {site.legalSuffix}</p>
      <p class="hidden md:block">Seit {site.foundedYear} in Cronenberg verwurzelt.</p>
      <p>
        Umsetzung:
        <a
          href="https://pixelschmied.de"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white font-semibold hover:underline underline-offset-2"
        >
          pixelschmied.de
        </a>
      </p>
    </div>
  </div>
</footer>
