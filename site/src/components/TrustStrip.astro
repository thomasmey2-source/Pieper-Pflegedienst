---
import { site } from '@/config/site';

type Stat = { value: string; label: string; reverse?: boolean };

const stats: Stat[] = [
  { value: site.stats.yearsInBusiness, label: 'Jahre in Cronenberg' },
  { value: site.stats.patients,         label: 'Patienten betreut' },
  // Bei der Pflegenote: Label vor Zahl, sonst liest sich's wie "1 Pflegenote"
  { value: site.stats.mdkNote,          label: 'MDK-Pflegenote',  reverse: true },
  { value: site.stats.teamSize,         label: 'Mitarbeitende' },
];
---

<div class="bg-surface border-y border-line">
  <div class="container-content py-6 md:py-7 grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6">
    {stats.map(({ value, label, reverse }, i) => (
      <div class:list={[
        'flex items-center text-center md:items-baseline md:gap-3',
        reverse
          ? 'flex-col-reverse md:flex-row-reverse md:justify-end'
          : 'flex-col md:flex-row',
        i > 0 ? 'md:border-l md:border-line/60 md:pl-6' : '',
      ]}>
        <div class="text-2xl md:text-3xl font-heading font-bold text-primary leading-none">
          {value}
        </div>
        <div class:list={[
          'text-xs-label text-ink-muted uppercase tracking-wider leading-tight',
          reverse ? 'mb-1 md:mb-0' : 'mt-1 md:mt-0',
        ]}>
          {label}
        </div>
      </div>
    ))}
  </div>
</div>
