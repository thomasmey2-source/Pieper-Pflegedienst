---
import { site } from '@/config/site';

const stats = [
  { value: site.stats.yearsInBusiness, label: 'Jahre in Cronenberg' },
  { value: site.stats.patients,         label: 'Patienten betreut' },
  { value: site.stats.mdkNote,          label: 'MDK-Pflegenote' },
  { value: site.stats.teamSize,         label: 'Mitarbeitende' },
];
---

<div class="bg-surface border-y border-line">
  <div class="container-content py-6 md:py-7 grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6">
    {stats.map(({ value, label }, i) => (
      <div class:list={[
        'flex flex-col items-center text-center md:flex-row md:items-baseline md:gap-3',
        i > 0 ? 'md:border-l md:border-line/60 md:pl-6' : '',
      ]}>
        <div class="text-2xl md:text-3xl font-heading font-bold text-primary leading-none">
          {value}
        </div>
        <div class="text-xs-label text-ink-muted mt-1 md:mt-0 uppercase tracking-wider leading-tight">
          {label}
        </div>
      </div>
    ))}
  </div>
</div>
