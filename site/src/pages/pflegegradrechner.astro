---
import Base from '@/layouts/Base.astro';
import PflegegradeOverview from '@/components/PflegegradeOverview.astro';
import { Wizard } from '@/components/pflegegradrechner/Wizard';

const title = 'Pflegegradrechner';
const description =
  'Kostenloser Pflegegradrechner für pflegende Angehörige in Wuppertal-Cronenberg und Umgebung: Voraussichtlichen Pflegegrad und Pflegegeld in wenigen Minuten einschätzen. Unverbindlich, anonym, DSGVO-konform — Beratung durch Pflegedienst Pieper.';

const faqs = [
  {
    q: 'Wie genau ist das Ergebnis?',
    a: 'Unser Rechner basiert auf dem offiziellen Begutachtungs-Instrument (NBA) des Medizinischen Dienstes. Das Ergebnis ist eine fundierte Schätzung — verbindlich ist nur die Begutachtung durch den MD nach einem persönlichen Termin bei Ihnen zu Hause.',
  },
  {
    q: 'Was kostet ein Pflegegrad-Antrag?',
    a: 'Der Antrag bei Ihrer Pflegekasse ist kostenfrei. Auch die Begutachtung durch den Medizinischen Dienst übernimmt die Pflegekasse. Unsere Beratung im Vorfeld ist für Sie ebenfalls kostenlos und unverbindlich.',
  },
  {
    q: 'Wer hilft mir beim MD-Gutachten?',
    a: 'Wir bereiten Sie auf den Termin vor: Wir besprechen, was abgefragt wird, helfen beim Pflegetagebuch und sind auf Wunsch beim Termin dabei. So fühlen sich Betroffene und Angehörige gut vorbereitet und nicht allein gelassen.',
  },
  {
    q: 'Wie unterscheiden sich die Pflegegrade?',
    a: 'Pflegegrad 1 steht für eine geringe, Pflegegrad 5 für die schwerste Beeinträchtigung. Mit steigendem Pflegegrad erhöhen sich die Leistungen: Pflegegeld, Pflegesachleistungen, Verhinderungspflege und der Entlastungsbetrag. Eine Übersicht der aktuellen Beträge erhalten Sie bei uns gerne im Beratungsgespräch.',
  },
];
---

<Base title={title} description={description}>
  <section class="relative bg-gradient-to-br from-primary to-primary-dark text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <defs>
          <pattern id="dots-pgr" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="white" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots-pgr)" />
      </svg>
    </div>
    <div class="container-content relative py-14 md:py-20">
      <p class="eyebrow text-care-soft mb-4">Kostenlos · Unverbindlich</p>
      <h1 class="text-h1-mobile md:text-h1 font-heading text-white mb-5 max-w-3xl">
        Pflegegradrechner — kostenlos & unverbindlich.
      </h1>
      <p class="text-lead text-white/90 max-w-prose-comfort">
        Beantworten Sie wenige Fragen und erfahren Sie in wenigen Minuten
        Ihren voraussichtlichen Pflegegrad.
      </p>
      <p class="mt-4 text-small text-white/60">
        Anonym · DSGVO-konform · Keine Anmeldung nötig
      </p>
    </div>
  </section>

  <!-- Pflegegrade im Überblick -->
  <section class="section bg-[#F0F4FB]">
    <div class="container-content">
      <h2 class="text-h3 font-heading text-ink mb-5">Pflegegrade im Überblick</h2>
      <PflegegradeOverview />
    </div>
  </section>

  <section class="section">
    <div class="container-content">
      <div class="mx-auto max-w-3xl">
        <Wizard client:load />
      </div>
    </div>
  </section>

  <section class="section bg-surface-alt">
    <div class="container-content">
      <div class="mx-auto max-w-3xl">
        <p class="eyebrow text-center">Häufige Fragen</p>
        <h2 class="mt-3 text-center font-heading text-h2-mobile md:text-h2">
          Was Sie zum Pflegegrad wissen sollten
        </h2>
        <dl class="mt-10 space-y-4">
          {
            faqs.map((faq) => (
              <details class="card group">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-heading text-h3">
                  <span>{faq.q}</span>
                  <span
                    class="mt-1 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary-soft text-primary transition-transform group-open:rotate-45"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <p class="mt-4 text-body text-ink-muted">{faq.a}</p>
              </details>
            ))
          }
        </dl>

        <div class="mt-12 text-center">
          <p class="text-body text-ink-muted">
            Noch Fragen? Wir beraten Sie persönlich und kostenfrei.
          </p>
          <a href="/kontakt/" class="btn-care btn-lg mt-4">
            Beratungstermin vereinbaren
          </a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.a,
      },
    })),
  })} />
</Base>
