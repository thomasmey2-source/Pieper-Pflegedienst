const posts = [
  {
    title: 'Pflegegrad beantragen — Schritt für Schritt',
    excerpt: 'Vom ersten Anruf bei der Pflegekasse bis zur Begutachtung: So bereiten Sie sich richtig vor und vermeiden die häufigsten Fehler.',
    date: '12. Mai 2026',
    slug: '/ratgeber/pflegegrad-beantragen/',
    image: '/images/ratgeber-beratung.webp',
    imageAlt: 'Pflegekraft und Angehörige bei der Beratung am Tisch',
  },
  {
    title: 'Verhinderungspflege einfach erklärt',
    excerpt: 'Bis zu 1.612 Euro pro Jahr stehen Ihnen zu, wenn Sie als pflegende Angehörige eine Auszeit brauchen — wir zeigen, wie es geht.',
    date: '28. April 2026',
    slug: '/ratgeber/verhinderungspflege-erklaert/',
    image: '/images/ratgeber-beratung-3.webp',
    imageAlt: 'Pflegekraft begrüßt Angehörige an der Haustür',
  },
  {
    title: 'Entlastungsbetrag richtig nutzen',
    excerpt: '125 Euro monatlich für Betreuung und Entlastung — viele lassen das Geld liegen. Wofür Sie es einsetzen können und wie Sie abrechnen.',
    date: '10. April 2026',
    slug: '/ratgeber/entlastungsbetrag/',
    image: '/images/ratgeber-beratung-2.webp',
    imageAlt: 'Pflegekraft und ältere Dame lesen gemeinsam ein Dokument',
  },
];
---

<Base title="Ratgeber für pflegende Angehörige" description={description}>
  <section class="relative bg-gradient-to-br from-primary to-primary-dark text-white">
    <div class="absolute inset-0 opacity-10 overflow-hidden" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <defs>
          <pattern id="dots-r" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1.5" fill="white" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots-r)" />
      </svg>
    </div>
    <div class="container-content relative py-16 md:py-24">
      <p class="eyebrow text-care-soft mb-4">Ratgeber</p>
      <h1 class="text-h1-mobile md:text-h1 font-heading text-white mb-5 max-w-3xl">
        Ratgeber für pflegende Angehörige.
      </h1>
      <p class="text-lead text-white/90 mb-8 max-w-prose-comfort">
        Pflege bringt viele Fragen mit sich — finanziell, bürokratisch,
        emotional. Hier finden Sie verständliche Antworten ohne Behördendeutsch.
      </p>

      <form class="max-w-xl relative" onsubmit="event.preventDefault();" role="search" data-search-form>
        <label for="ratgeber-search" class="sr-only">Webseite durchsuchen</label>
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
               class="absolute left-4 top-1/2 -translate-y-1/2 text-ink-muted pointer-events-none" aria-hidden="true">
            <path d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 1 0-.7.7l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0A4.5 4.5 0 1 1 14 9.5 4.5 4.5 0 0 1 9.5 14z" />
          </svg>
          <input
            id="ratgeber-search"
            type="search"
            placeholder="Suchen — z. B. Pflegegrad, Verhinderung, Karriere..."
            autocomplete="off"
            class="w-full h-14 pl-12 pr-10 rounded-btn bg-white/95 text-ink placeholder:text-ink-muted shadow-md focus:outline-none focus:ring-2 focus:ring-white/40"
            data-search-input
          />
          <button
            type="button"
            class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-7 h-7 rounded-full text-ink-muted hover:text-ink hover:bg-surface-alt flex items-center justify-center"
            aria-label="Suche leeren"
            data-search-clear
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>

        <!-- Ergebnis-Dropdown -->
        <div
          class="hidden absolute left-0 right-0 top-full mt-2 bg-white rounded-card shadow-xl border border-line z-50 overflow-hidden text-ink"
          data-search-dropdown
          role="listbox"
        >
          <!-- Treffer -->
          <div data-search-results class="max-h-[60vh] overflow-y-auto"></div>

          <!-- Keine Treffer -->
          <div data-search-empty class="hidden p-6 text-center">
            <div class="w-12 h-12 rounded-btn bg-surface-alt text-ink-muted mx-auto mb-3 flex items-center justify-center" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                <line x1="8" y1="11" x2="14" y2="11"/>
              </svg>
            </div>
            <p class="text-body text-ink mb-1">
              Leider keine Treffer für <strong data-search-empty-query>„"</strong>.
            </p>
            <p class="text-small text-ink-muted mb-4">
              Sollen wir bei Google nach Ihrem Begriff suchen?
            </p>
            <a
              data-search-google
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary btn-md inline-flex items-center gap-2"
            >
              Bei Google suchen
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M7 17 17 7"/><path d="M7 7h10v10"/>
              </svg>
            </a>
          </div>
        </div>
      </form>

      <script is:inline define:vars={{ searchIndex }}>
        (function () {
          const form = document.querySelector('[data-search-form]');
          if (!form) return;

          const input = form.querySelector('[data-search-input]');
          const dropdown = form.querySelector('[data-search-dropdown]');
          const resultsEl = form.querySelector('[data-search-results]');
          const emptyEl = form.querySelector('[data-search-empty]');
          const emptyQueryEl = form.querySelector('[data-search-empty-query]');
          const googleLink = form.querySelector('[data-search-google]');
          const clearBtn = form.querySelector('[data-search-clear]');

          // Diakritika & ß normalisieren
          function normalize(str) {
            return (str || '')
              .toLowerCase()
              .replace(/ä/g, 'a')
              .replace(/ö/g, 'o')
              .replace(/ü/g, 'u')
              .replace(/ß/g, 'ss')
              .replace(/[^\w\s§-]/g, ' ');
          }

          function score(item, terms) {
            const title = normalize(item.title);
            const excerpt = normalize(item.excerpt);
            const keywords = (item.keywords || []).map(normalize).join(' ');
            let s = 0;
            for (const t of terms) {
              if (!t) continue;
              if (title.includes(t)) s += 5;
              if (keywords.includes(t)) s += 3;
              if (excerpt.includes(t)) s += 1;
            }
            return s;
          }

          function renderResults(items, query) {
            resultsEl.innerHTML = items.map((it) => `
              <a href="${it.url}" class="block px-5 py-4 hover:bg-surface border-b border-line/40 last:border-b-0 transition-colors">
                <div class="flex items-start gap-3">
                  <span class="inline-flex items-center text-[10px] font-bold tracking-wider uppercase text-primary bg-primary-soft px-2 py-0.5 rounded mt-0.5 flex-shrink-0">${it.type}</span>
                  <div class="flex-1 min-w-0">
                    <p class="text-body font-semibold text-ink mb-0.5">${it.title}</p>
                    <p class="text-small text-ink-muted line-clamp-2">${it.excerpt}</p>
                  </div>
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-ink-muted/50 mt-1 flex-shrink-0" aria-hidden="true">
                    <polyline points="9 18 15 12 9 6"/>
                  </svg>
                </div>
              </a>
            `).join('');
          }

          function showDropdown() { dropdown.classList.remove('hidden'); }
          function hideDropdown() { dropdown.classList.add('hidden'); }

          function performSearch(query) {
            const q = (query || '').trim();
            if (q.length < 2) {
              hideDropdown();
              clearBtn.classList.add('hidden');
              return;
            }
            clearBtn.classList.remove('hidden');

            const terms = normalize(q).split(/\s+/).filter(Boolean);
            const scored = searchIndex
              .map((item) => ({ item, s: score(item, terms) }))
              .filter((r) => r.s > 0)
              .sort((a, b) => b.s - a.s)
              .slice(0, 8)
              .map((r) => r.item);

            if (scored.length > 0) {
              emptyEl.classList.add('hidden');
              resultsEl.classList.remove('hidden');
              renderResults(scored, q);
            } else {
              resultsEl.classList.add('hidden');
              resultsEl.innerHTML = '';
              emptyEl.classList.remove('hidden');
              emptyQueryEl.textContent = `„${q}"`;
              googleLink.setAttribute('href', `https://www.google.com/search?q=${encodeURIComponent(q)}`);
            }
            showDropdown();
          }

          let debounceTimer;
          input.addEventListener('input', (e) => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => performSearch(e.target.value), 120);
          });

          input.addEventListener('focus', () => {
            if (input.value.trim().length >= 2) performSearch(input.value);
          });

          clearBtn.addEventListener('click', () => {
            input.value = '';
            hideDropdown();
            clearBtn.classList.add('hidden');
            input.focus();
          });

          // Click outside → schließen
          document.addEventListener('click', (e) => {
            if (!form.contains(e.target)) hideDropdown();
          });

          // Escape → schließen
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
              hideDropdown();
              input.blur();
            }
          });
        })();
      </script>
    </div>
  </section>

  <section class="section">
    <div class="container-content">
      <div class="max-w-prose-comfort mb-10 md:mb-14">
        <p class="eyebrow mb-3">Themenwelten</p>
        <h2 class="text-h2-mobile md:text-h2 font-heading text-ink mb-4">
          Worüber möchten Sie mehr wissen?
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {categories.map((c) => (
          <a href={c.href} class="card-hover block group">
            <div class="w-12 h-12 rounded-btn bg-primary-soft text-primary flex items-center justify-center mb-4" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d={c.icon} />
              </svg>
            </div>
            <h3 class="text-h3 font-heading text-ink mb-2 group-hover:text-primary-hover transition-colors">
              {c.title}
            </h3>
            <p class="text-body text-ink-muted">{c.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-section-mobile md:py-12">
    <div class="container-content">
      <div class="bg-care rounded-card overflow-hidden shadow-md grid md:grid-cols-12 gap-0 items-stretch">
        <div class="md:col-span-8 p-8 md:p-10 lg:p-12 text-white">
          <p class="eyebrow text-white/80 mb-3">Pflegegradrechner</p>
          <h2 class="text-h3 md:text-h2 font-heading text-white mb-3">
            Pflegegrad in 5 Minuten einschätzen.
          </h2>
          <p class="text-body md:text-lead text-white/90 mb-6 max-w-prose-comfort">
            Bevor Sie sich durch Anträge wühlen: Unser kostenloser Rechner gibt
            eine erste Orientierung — anonym und ohne Anmeldung.
          </p>
          <a href="/pflegegradrechner/" class="btn btn-md bg-white text-care hover:bg-white/95 shadow-md">
            Jetzt berechnen
          </a>
        </div>
        <div class="md:col-span-4 hidden md:block relative">
          <img
            src="/images/pflegegradrechner-illustration.webp"
            alt="Illustration: Pflegegrad berechnen — Klemmbrett, Taschenrechner und Stoppuhr"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container-content">
      <div class="max-w-prose-comfort mb-10 md:mb-14">
        <p class="eyebrow mb-3">Aktuelle Beiträge</p>
        <h2 class="text-h2-mobile md:text-h2 font-heading text-ink mb-4">
          Frisch aus dem Ratgeber.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
        {posts.map((p) => (
          <article class="card-hover flex flex-col">
            <div class="aspect-[16/10] rounded-btn overflow-hidden mb-4">
              <img
                src={p.image}
                alt={p.imageAlt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <time class="text-xs-label text-ink-muted uppercase tracking-wider mb-2">{p.date}</time>
            <h3 class="text-h4 font-heading text-ink mb-2">{p.title}</h3>
            <p class="text-body text-ink-muted mb-4 flex-1">{p.excerpt}</p>
            <a href={p.slug} class="text-small text-primary font-semibold hover:text-primary-hover">
              Weiterlesen →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-content">
      <div class="bg-primary rounded-card p-8 md:p-12 lg:p-16 text-white text-center max-w-prose-comfort mx-auto">
        <h2 class="text-h2-mobile md:text-h2 font-heading text-white mb-4">
          Persönliche Beratung statt Suchen?
        </h2>
        <p class="text-lead text-white/90 mb-8">
          Manchmal hilft ein Anruf mehr als zehn Artikel. Wir nehmen uns Zeit
          für Ihre Fragen — kostenlos und unverbindlich.
        </p>
        <a href="/kontakt/" class="btn-care btn-lg">Sprechen Sie uns an</a>
      </div>
    </div>
  </section>
</Base>
